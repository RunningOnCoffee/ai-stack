# ============================================================================
#  Lokaler AI-Stack — Umgebung
#  cp .env.example .env  und Werte anpassen (mind. HF_TOKEN + HF_HOME).
#  Die .env ist die maßgebliche Quelle — diese Vorlage aktuell halten!
# ============================================================================

# --- Multi-Arch: base + Arch-Override automatisch mergen ---------------------
# arm64 (DGX Spark, Standard):
COMPOSE_FILE=compose/base.yml:compose/arm64.yml
# x86 (Phase 2): stattdessen ->  compose/base.yml:compose/x86.yml
COMPOSE_PROJECT_NAME=ai-stack

# --- Hugging Face -----------------------------------------------------------
HF_TOKEN=hf_changeme
# Gemeinsamer Modell-Cache (Bind-Mount). Persistiert Gewichte über Neustarts.
# ACHTUNG: relative Pfade löst Compose relativ zur Compose-Datei (compose/) auf,
# nicht zum Projektordner -> absoluten Pfad verwenden.
HF_HOME=/srv/docker/ai-stack/models/hf-cache

# --- Gateway (LiteLLM) ------------------------------------------------------
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest
# TODO: per Digest pinnen
LITELLM_PORT=4000
# Vor LAN-Nutzung UNBEDINGT eigenen Key setzen:
LITELLM_MASTER_KEY=sk-local-changeme

# --- Vektor-DB (Qdrant) -----------------------------------------------------
QDRANT_IMAGE=qdrant/qdrant:latest
# TODO: per Digest pinnen (multi-arch)
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- LLM: Qwen3.6-27B auf vLLM (Core, always-on) ----------------------------
# WICHTIG (Spark): amd64-:latest schlägt mit "exec format error" fehl.
# Nur ein aarch64/sm_121-Image verwenden und per Digest pinnen.
# 26.06-py3 NICHT nehmen: API-Server-Bug (prometheus-fastapi-instrumentator 8.0.0
# inkompatibel mit starlette 1.3.1 -> jede Anfrage liefert HTTP 500).
# 26.04-py3 ist erprobt. Weitere Optionen: docs/spark-setup.md.
VLLM_IMAGE=nvcr.io/nvidia/vllm:26.04-py3
# TODO: durch @sha256:... ersetzen

# Modell-Variante — idealerweise eine NVFP4-Quantisierung (Blackwell-nativ).
# Hinweis: Liegt der Snapshot schon im Cache, kann hier auch der lokale
# Snapshot-Pfad (Container-Sicht, /root/.cache/huggingface/hub/...) stehen —
# nötig z.B. wenn upstream die Gewichte geändert hat (vermeidet Neu-Download).
LLM_MODEL_ID=unsloth/Qwen3.6-27B-NVFP4
# Tokenizer aus dem Original-Repo (erprobt mit der unsloth-NVFP4-Variante):
LLM_TOKENIZER=Qwen/Qwen3.6-27B
LLM_SERVED_NAME=qwen3.6-27b
LLM_PORT=8000

# Unified-Memory-Tuning (Core lässt Platz für On-demand-Dienste)
# Summe der gpu-memory-utilization aller gleichzeitig laufenden Dienste <= ~0.85!
LLM_GPU_MEM_UTIL=0.50
# Anteil der 128 GB für diesen Dienst; bei 2 LLMs always-on auf ~0.35 senken
LLM_MAX_LEN=32768
# Kontextfenster (klein starten, dann erhöhen)
LLM_KV_DTYPE=auto
# bei Bedarf fp8 für längeren Kontext
LLM_MAX_SEQS=4
# max. parallele Sequenzen (klein halten auf Unified Memory)
# NVFP4-Recipe braucht ggf. --enforce-eager gegen Startup-OOM (siehe memory-budget.md)
LLM_EXTRA_ARGS=--trust-remote-code

# --- LLM-fast: Qwen3.6-35B-A3B MoE (Profil `fast`, on-demand) ---------------
# Startet NICHT im Standard-`make up` — separat via `make up-fast`.
LLM_FAST_MODEL_ID=unsloth/Qwen3.6-35B-A3B-NVFP4
LLM_FAST_TOKENIZER=Qwen/Qwen3.6-35B-A3B
LLM_FAST_SERVED_NAME=qwen3.6-35b-fast
LLM_FAST_PORT=8001
# Koexistenz mit dem 27B: Quoten-Summe beachten. Solo erprobt: 0.45 + 131072 Kontext.
LLM_FAST_GPU_MEM_UTIL=0.30
LLM_FAST_MAX_LEN=40960
LLM_FAST_MAX_SEQS=16
LLM_FAST_KV_DTYPE=fp8

# --- TTS: Qwen3-TTS-0.6B CustomVoice (Profil `voice`) -----------------------
# Fertiges sm_121/ARM64-Image (MIT) — Skripte/Voices via services/tts/.
# Setup-Schritte: services/tts/README.md. Start: make up-tts
TTS_IMAGE=martinb78/faster-qwen3-tts-dgx-spark:latest
TTS_MODEL_ID=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
# Lokaler Modellpfad (Host-Seite; via `hf download --local-dir` befüllt):
TTS_MODEL_DIR=/srv/docker/ai-stack/models/tts/Qwen3-TTS-12Hz-0.6B-CustomVoice
TTS_PORT=8002
TTS_MAX_SEQ_LEN=2048

# --- STT: Qwen3-ASR-0.6B (Profil `voice`) -----------------------------------
# Fertiges sm_121a/ARM64-Image (AEON-7/qwen3-asr-server): vLLM-nativ,
# OpenAI-kompatibles /v1/audio/transcriptions. Start: make up-stt
# Modell lädt der Container beim Erststart selbst (~1.3 GB).
# ACHTUNG: Container-intern Port 8001 (Upstream-Default; der im Image
# eingebaute Healthcheck prüft dort — deshalb nicht auf 8000 umbiegen).
STT_IMAGE=ghcr.io/aeon-7/qwen3-asr-server:latest
STT_MODEL_ID=Qwen/Qwen3-ASR-0.6B
# Qualitätsvariante: Qwen/Qwen3-ASR-1.7B (dann STT_GPU_MEM_UTIL >= 0.10)
STT_SERVED_NAME=qwen3-asr
STT_PORT=8003
STT_GPU_MEM_UTIL=0.08
STT_MAX_LEN=8192
STT_MAX_SEQS=4

# --- Chat-UI: LibreChat + MongoDB (Core, CPU-only) ---------------------------
# Front-end des Stacks (MIT-Lizenz). Konfig: services/librechat/librechat.yaml
# Multi-arch-Image (arm64 verifiziert). TODO: per Digest pinnen
LIBRECHAT_IMAGE=ghcr.io/danny-avila/librechat:v0.8.7
LIBRECHAT_PORT=3080
LIBRECHAT_APP_TITLE=AI-Stack
MONGO_IMAGE=mongo:8.0
# Secrets einmalig generieren (NICHT die Platzhalter verwenden!):
#   LIBRECHAT_JWT_SECRET / LIBRECHAT_JWT_REFRESH_SECRET:  openssl rand -hex 32
#   LIBRECHAT_CREDS_KEY: openssl rand -hex 32
#   LIBRECHAT_CREDS_IV:  openssl rand -hex 16
LIBRECHAT_JWT_SECRET=changeme
LIBRECHAT_JWT_REFRESH_SECRET=changeme
LIBRECHAT_CREDS_KEY=changeme
LIBRECHAT_CREDS_IV=changeme
# Serverseitiger Think-Filter beim Vorlesen (patches/TTSService.js), Default: aktiv.
# Nur setzen, wenn der Think-Block MIT vorgelesen werden soll:
# TTS_READ_THINK=true

# --- On-demand-Modelle (Profil rag) — beim Ausbau befüllen -------------------
EMBED_MODEL_ID=Qwen/Qwen3-Embedding-4B
RERANK_MODEL_ID=Qwen/Qwen3-Reranker-4B
